generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model activity_logs {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id     String?   @db.Uuid
  action      String    @db.VarChar(255)
  entity_type String    @db.VarChar(100)
  entity_id   String?   @db.VarChar(100)
  timestamp   DateTime? @default(now()) @db.Timestamptz(6)
  users       users?    @relation(fields: [user_id], references: [id], onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model categories {
  id         String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenant_id  String       @db.Uuid
  name       String       @db.VarChar(100)
  sort_order Int?         @default(0)
  created_at DateTime?    @default(now()) @db.Timestamptz(6)
  updated_at DateTime?    @default(now()) @db.Timestamptz(6)
  tenants    tenants      @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  menu_items menu_items[]

  @@unique([tenant_id, name], map: "unique_tenant_category")
  @@index([tenant_id], map: "idx_categories_tenant")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model menu_items {
  id           String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenant_id    String        @db.Uuid
  category_id  String?       @db.Uuid
  name         String        @db.VarChar(255)
  description  String?
  price        Decimal       @db.Decimal(10, 2)
  icon         String?       @db.VarChar(50)
  is_available Boolean?      @default(true)
  created_at   DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at   DateTime?     @default(now()) @db.Timestamptz(6)
  categories   categories?   @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  tenants      tenants       @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  order_items  order_items[]

  @@index([tenant_id], map: "idx_menu_items_tenant")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model order_items {
  id           String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  order_id     String      @db.Uuid
  menu_item_id String?     @db.Uuid
  quantity     Int         @default(1)
  unit_price   Decimal     @db.Decimal(10, 2)
  price        Decimal     @db.Decimal(10, 2)
  created_at   DateTime?   @default(now()) @db.Timestamptz(6)
  menu_items   menu_items? @relation(fields: [menu_item_id], references: [id], onUpdate: NoAction)
  orders       orders      @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([order_id], map: "idx_order_items_order")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model orders {
  id            String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenant_id     String        @db.Uuid
  table_id      String?       @db.Uuid
  waiter_id     String?       @db.Uuid
  customer_name String?       @db.VarChar(255)
  status        order_status? @default(PENDING)
  total_amount  Decimal       @default(0.00) @db.Decimal(10, 2)
  created_at    DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?     @default(now()) @db.Timestamptz(6)
  order_items   order_items[]
  tables        tables?       @relation(fields: [table_id], references: [id], onUpdate: NoAction)
  tenants       tenants       @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users         users?        @relation(fields: [waiter_id], references: [id], onUpdate: NoAction)
  receipts      receipts?

  @@index([status], map: "idx_orders_status")
  @@index([tenant_id], map: "idx_orders_tenant")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tables {
  id          String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenant_id   String        @db.Uuid
  number      String        @db.VarChar(50)
  capacity    Int?          @default(4)
  status      table_status? @default(AVAILABLE)
  created_at  DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?     @default(now()) @db.Timestamptz(6)
  waiter_id   String?       @db.Uuid
  guest_count Int?          @default(0)
  orders      orders[]
  tenants     tenants       @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users       users?        @relation(fields: [waiter_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([tenant_id, number], map: "unique_tenant_table_number")
  @@index([tenant_id], map: "idx_tables_tenant")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tenants {
  id                  String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                String               @db.VarChar(255)
  slug                String               @unique @db.VarChar(255)
  logo                String?
  primary_color       String?              @default("#F97316") @db.VarChar(50)
  secondary_color     String?              @default("#0B1630") @db.VarChar(50)
  is_active           Boolean?             @default(true)
  phone               String?              @db.VarChar(50)
  email               String?              @db.VarChar(255)
  address             String?
  currency_code       String?              @default("ETB") @db.VarChar(10)
  currency_symbol     String?              @default("ETB") @db.VarChar(10)
  created_at          DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?            @default(now()) @db.Timestamptz(6)
  categories          categories[]
  conversations       conversations[]
  menu_items          menu_items[]
  messages            messages[]
  notifications       notifications[]
  orders              orders[]
  receipts            receipts[]
  restaurant_settings restaurant_settings?
  subscriptions       subscriptions[]
  tables              tables[]
  users               users[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id                        String                      @id @db.Uuid
  tenant_id                 String?                     @db.Uuid
  email                     String                      @unique @db.VarChar(255)
  first_name                String                      @db.VarChar(100)
  last_name                 String                      @db.VarChar(100)
  role                      user_role?                  @default(WAITER)
  is_active                 Boolean?                    @default(true)
  created_at                DateTime?                   @default(now()) @db.Timestamptz(6)
  updated_at                DateTime?                   @default(now()) @db.Timestamptz(6)
  activity_logs             activity_logs[]
  conversation_participants conversation_participants[]
  messages                  messages[]
  notifications             notifications[]
  orders                    orders[]
  receipts                  receipts[]
  tables                    tables[]
  tenants                   tenants?                    @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenant_id], map: "idx_users_tenant")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model conversation_participants {
  id              String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  conversation_id String        @db.Uuid
  user_id         String        @db.Uuid
  joined_at       DateTime?     @default(now()) @db.Timestamptz(6)
  conversations   conversations @relation(fields: [conversation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users           users         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([conversation_id, user_id], map: "unique_conversation_participant")
  @@index([conversation_id], map: "idx_conversation_participants_conv")
  @@index([user_id], map: "idx_conversation_participants_user")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model conversations {
  id                        String                      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenant_id                 String                      @db.Uuid
  name                      String?                     @db.VarChar(255)
  created_at                DateTime?                   @default(now()) @db.Timestamptz(6)
  conversation_participants conversation_participants[]
  tenants                   tenants                     @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  messages                  messages[]

  @@index([tenant_id], map: "idx_conversations_tenant")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model messages {
  id              String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenant_id       String        @db.Uuid
  conversation_id String        @db.Uuid
  sender_id       String        @db.Uuid
  content         String
  created_at      DateTime?     @default(now()) @db.Timestamptz(6)
  conversations   conversations @relation(fields: [conversation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users           users         @relation(fields: [sender_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tenants         tenants       @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([conversation_id], map: "idx_messages_conv")
  @@index([tenant_id], map: "idx_messages_tenant")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model notifications {
  id         String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenant_id  String     @db.Uuid
  user_id    String?    @db.Uuid
  role       user_role?
  title      String     @db.VarChar(255)
  message    String
  is_read    Boolean?   @default(false)
  created_at DateTime?  @default(now()) @db.Timestamptz(6)
  tenants    tenants    @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users?     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenant_id], map: "idx_notifications_tenant")
  @@index([user_id], map: "idx_notifications_user")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model plans {
  id            String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name          String          @unique @db.VarChar(100)
  price         Decimal         @default(0.00) @db.Decimal(10, 2)
  features      Json?           @default("[]")
  max_users     Int?            @default(-1)
  max_tables    Int?            @default(-1)
  created_at    DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?       @default(now()) @db.Timestamptz(6)
  subscriptions subscriptions[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model receipts {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenant_id       String    @db.Uuid
  order_id        String    @unique @db.Uuid
  cashier_id      String?   @db.Uuid
  receipt_number  String    @unique @db.VarChar(100)
  subtotal        Decimal   @db.Decimal(10, 2)
  tax_amount      Decimal   @default(0.00) @db.Decimal(10, 2)
  discount_amount Decimal   @default(0.00) @db.Decimal(10, 2)
  total_amount    Decimal   @db.Decimal(10, 2)
  payment_method  String    @db.VarChar(50)
  payment_status  String?   @default("PAID") @db.VarChar(50)
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  users           users?    @relation(fields: [cashier_id], references: [id], onUpdate: NoAction)
  orders          orders    @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tenants         tenants   @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([order_id], map: "idx_receipts_order")
  @@index([tenant_id], map: "idx_receipts_tenant")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model restaurant_settings {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenant_id       String    @unique @db.Uuid
  timezone        String?   @default("UTC") @db.VarChar(100)
  tax_rate        Decimal?  @default(15.00) @db.Decimal(5, 2)
  receipt_footer  String?   @default("Thank you for dining with us!")
  logo_url        String?
  primary_color   String?   @default("#F97316") @db.VarChar(50)
  secondary_color String?   @default("#0B1630") @db.VarChar(50)
  business_hours  Json?     @default("{\"mon_fri\": \"08:00 AM - 10:00 PM\", \"sat_sun\": \"09:00 AM - 11:00 PM\"}")
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @default(now()) @db.Timestamptz(6)
  tenants         tenants   @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenant_id], map: "idx_restaurant_settings_tenant")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model subscriptions {
  id                   String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenant_id            String    @db.Uuid
  plan_id              String    @db.Uuid
  status               String    @default("ACTIVE") @db.VarChar(50)
  current_period_start DateTime? @default(now()) @db.Timestamptz(6)
  current_period_end   DateTime  @db.Timestamptz(6)
  created_at           DateTime? @default(now()) @db.Timestamptz(6)
  updated_at           DateTime? @default(now()) @db.Timestamptz(6)
  plans                plans     @relation(fields: [plan_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenants              tenants   @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenant_id], map: "idx_subscriptions_tenant")
}

enum order_status {
  PENDING
  PREPARING
  READY
  COMPLETED
  CANCELED
}

enum table_status {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
}

enum user_role {
  SUPER_ADMIN
  ADMIN
  WAITER
  KITCHEN_STAFF
  CASHIER
}
